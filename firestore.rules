rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- meta/stats -----------------------------------------------------
    // A single counter document tracking how many leader accounts exist
    // (meta/stats -> { leaderCount: number }). Anyone can read it (so the
    // portal can show a friendly "spots full" message before someone even
    // tries to sign up). It can only ever be created at 1, or incremented
    // by exactly 1 at a time, and can never exceed MAX_LEADER_ACCOUNTS
    // below — this is what makes the 9-account cap race-safe: two people
    // signing up at the same instant can't both succeed past 9.
    match /meta/stats {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.leaderCount == 1;
      allow update: if request.auth != null
                    && request.resource.data.leaderCount == resource.data.leaderCount + 1
                    && request.resource.data.leaderCount <= 9;
      allow delete: if false;
    }

    // ---- leaders/{uid} -----------------------------------------------
    // Anyone can read leader profiles (shown on the public site).
    // Only the signed-in leader who owns the document can edit it.
    // Creation has NO identity/email check — signup is open to anyone —
    // but is capped at 9 total accounts by checking the meta/stats
    // counter above. js/auth.js creates this document and bumps the
    // counter together in one transaction, so this rule and the
    // meta/stats rule together are what actually enforce the cap
    // server-side (the check in auth.js is just a friendlier first pass).
    match /leaders/{leaderId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.auth.uid == leaderId
                    && (!exists(/databases/$(database)/documents/meta/stats)
                        || get(/databases/$(database)/documents/meta/stats).data.leaderCount < 9);
      allow update: if request.auth != null && request.auth.uid == leaderId;
      allow delete: if false;
    }

    // ---- messages/{messageId} -----------------------------------------
    // Visitors (unauthenticated) can create a message for a leader or the
    // general inbox. A leader can read/mark-as-read messages addressed to
    // them personally, AND any message in the shared "general" inbox
    // (visible to all 9 leaders). Nobody can delete via the client.
    match /messages/{messageId} {
      allow create: if request.resource.data.keys().hasAll(['toLeaderId', 'fromName', 'fromEmail', 'body'])
                    && request.resource.data.fromName is string
                    && request.resource.data.fromEmail is string
                    && request.resource.data.body is string;
      allow read, update: if request.auth != null
                    && (request.auth.uid == resource.data.toLeaderId || resource.data.toLeaderId == "general");
      allow delete: if false;
    }

    // ---- notifications/{notificationId} --------------------------------
    match /notifications/{notificationId} {
      allow read, update: if request.auth != null && request.auth.uid == resource.data.leaderId;
      allow create: if request.auth != null;
      allow delete: if false;
    }

    // ---- announcements/{announcementId} --------------------------------
    // Public homepage feed of updates. Anyone (including signed-out
    // visitors) can read announcements. Only a signed-in leader — i.e.
    // one of the 9 accounts covered by the MAX_LEADER_ACCOUNTS cap above,
    // since that's the only way to obtain a Firebase Auth session in this
    // project — can create one, and only as themselves (authorId must
    // match their own uid; they cannot post as someone else). A leader
    // can only edit or delete their own announcements.
    //
    // Signed-out visitors are additionally allowed to nudge ONLY the
    // denormalized likeCount/commentCount fields by exactly ±1 per write
    // (isValidCounterUpdate below) — this is what powers the public
    // like/comment counts without giving visitors any other write access
    // to the post itself.
    function isValidCounterUpdate() {
      let diffKeys = request.resource.data.diff(resource.data).affectedKeys();
      let oldLike = ('likeCount' in resource.data) ? resource.data.likeCount : 0;
      let oldComment = ('commentCount' in resource.data) ? resource.data.commentCount : 0;
      return (diffKeys.hasOnly(['likeCount'])
              && request.resource.data.likeCount is int
              && request.resource.data.likeCount >= 0
              && (request.resource.data.likeCount == oldLike + 1
                  || request.resource.data.likeCount == oldLike - 1))
          || (diffKeys.hasOnly(['commentCount'])
              && request.resource.data.commentCount is int
              && request.resource.data.commentCount >= 0
              && (request.resource.data.commentCount == oldComment + 1
                  || request.resource.data.commentCount == oldComment - 1));
    }

    match /announcements/{announcementId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.authorId == request.auth.uid
                    && request.resource.data.keys().hasAll(['authorId', 'authorName', 'title', 'body', 'createdAt'])
                    && request.resource.data.title is string
                    && request.resource.data.title.size() > 0
                    && request.resource.data.title.size() <= 200
                    && request.resource.data.body is string
                    && request.resource.data.body.size() > 0
                    && request.resource.data.body.size() <= 5000;
      allow update: if (request.auth != null
                    && request.auth.uid == resource.data.authorId
                    && request.resource.data.authorId == resource.data.authorId)
                    || isValidCounterUpdate();
      allow delete: if request.auth != null && request.auth.uid == resource.data.authorId;

      // ---- announcements/{announcementId}/likes/{deviceId} -------------
      // One doc per visitor device (id generated client-side and stored in
      // localStorage). Anyone can create OR overwrite their own like doc —
      // write (not just create) matters here because if a like doc already
      // exists for that device (e.g. left over from earlier testing),
      // Firestore treats re-liking as an "update" rather than a "create";
      // only allowing create would silently reject that and make the like
      // never actually land, even though the UI showed it succeeding.
      match /likes/{likeId} {
        allow read: if true;
        allow write: if request.resource.data.keys().hasOnly(['createdAt']);
        allow delete: if true;
      }

      // ---- announcements/{announcementId}/comments/{commentId} ---------
      // Public comments. Every commenter — including visitors who never
      // create an account — is signed in anonymously by the client
      // (js/main.js calls signInAnonymously), so `uid` is a real,
      // unspoofable Firebase Auth id, not just a self-reported field. That
      // lets us safely allow a commenter to edit or delete ONLY their own
      // comment later, without requiring a real account.
      // Requires the "Anonymous" sign-in provider to be enabled in
      // Firebase Console > Authentication > Sign-in method.
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null
                      && request.resource.data.uid == request.auth.uid
                      && request.resource.data.keys().hasAll(['uid', 'name', 'body', 'createdAt'])
                      && request.resource.data.name is string
                      && request.resource.data.name.size() > 0
                      && request.resource.data.name.size() <= 80
                      && request.resource.data.body is string
                      && request.resource.data.body.size() > 0
                      && request.resource.data.body.size() <= 1000;
        allow update: if request.auth != null
                      && request.auth.uid == resource.data.uid
                      && request.resource.data.uid == resource.data.uid
                      && request.resource.data.name == resource.data.name
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['body', 'editedAt'])
                      && request.resource.data.body is string
                      && request.resource.data.body.size() > 0
                      && request.resource.data.body.size() <= 1000;
        allow delete: if request.auth != null && request.auth.uid == resource.data.uid;
      }
    }
  }
}
