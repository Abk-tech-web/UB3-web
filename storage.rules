rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ---- leader-photos/{uid} -------------------------------------------
    // Each leader's profile photo, stored at leader-photos/{their-uid}
    // (see js/dashboard.js). Anyone can view a photo (it's shown on the
    // dashboard and, if you wire it up, the public site) — only the
    // leader who owns that uid can upload/replace their own photo.
    // Capped at 5MB and must actually be an image file.
    match /leader-photos/{leaderId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == leaderId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if false;
    }

    // Deny everything else by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
